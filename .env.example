# ==============================================================================
# DataRefinery — Environment Variables Template
# ==============================================================================
#
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env         (macOS / Linux)
#   copy .env.example .env       (Windows)
#
# IMPORTANT: Never commit .env to version control.
#            The .gitignore file already excludes it.
# ==============================================================================

# ------------------------------------------------------------------------------
# Flask Web Application Settings
# ------------------------------------------------------------------------------

# Secret key for session signing (generate a strong random value for production)
# FLASK_SECRET_KEY=your-very-secret-key-here

# Enable/disable Flask debug mode (set to false in production)
# FLASK_DEBUG=true

# Host and port for the development server
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5000

# Flask environment: development | production | testing
# FLASK_ENV=development

# ------------------------------------------------------------------------------
# Upload Settings
# ------------------------------------------------------------------------------

# Maximum upload file size in megabytes (default: 32 MB)
# MAX_UPLOAD_MB=32

# Directory where uploaded files and pipeline outputs are stored
# (relative to project root, or an absolute path)
# UPLOAD_FOLDER=uploads

# Auto-delete session folders after this many hours (default: 2)
# SESSION_MAX_AGE_HOURS=2


# ------------------------------------------------------------------------------
# Pipeline I/O paths (override CLI defaults if desired)
# ------------------------------------------------------------------------------

# Path to the raw input CSV file
# Default: data/raw_orders.csv
# PIPELINE_INPUT_PATH=data/raw_orders.csv

# Directory where output reports are written
# Default: reports
# PIPELINE_OUTPUT_DIR=reports

# ------------------------------------------------------------------------------
# Logging (optional)
# ------------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
# LOG_LEVEL=INFO

# Path to write log file (leave empty to log to stdout only)
# LOG_FILE=

# ------------------------------------------------------------------------------
# Future: Database connection (uncomment if adding DB persistence)
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/datapipeline
# DATABASE_POOL_SIZE=5

# ------------------------------------------------------------------------------
# Future: Cloud storage (uncomment if reading/writing from S3 or GCS)
# ------------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name
