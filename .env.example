# ==============================================================================
# BB DataRefinery — Environment Variables Template
# ==============================================================================
#
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env         (macOS / Linux)
#   copy .env.example .env       (Windows)
#
# IMPORTANT: Never commit .env to version control.
#            The .gitignore file already excludes it.
#
# This project currently uses no required runtime secrets.
# Variables below are optional and provided for future extensibility.
# ==============================================================================

# ------------------------------------------------------------------------------
# Pipeline I/O paths (override CLI defaults if desired)
# ------------------------------------------------------------------------------

# Path to the raw input CSV file
# Default: data/raw_orders.csv
# PIPELINE_INPUT_PATH=data/raw_orders.csv

# Directory where output reports are written
# Default: reports
# PIPELINE_OUTPUT_DIR=reports

# ------------------------------------------------------------------------------
# Logging (optional)
# ------------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
# LOG_LEVEL=INFO

# Path to write log file (leave empty to log to stdout only)
# LOG_FILE=

# ------------------------------------------------------------------------------
# Future: Database connection (uncomment if adding DB persistence)
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/datapipeline
# DATABASE_POOL_SIZE=5

# ------------------------------------------------------------------------------
# Future: Cloud storage (uncomment if reading/writing from S3 or GCS)
# ------------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET_NAME=your-bucket-name
