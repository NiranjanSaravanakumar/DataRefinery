# ==============================================================================
# DataRefinery — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Python bytecode & cache
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# ------------------------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/
pip-wheel-metadata/

# ------------------------------------------------------------------------------
# Testing & coverage
# ------------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.nox/

# ------------------------------------------------------------------------------
# Type checkers
# ------------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# ------------------------------------------------------------------------------
# Linters & formatters
# ------------------------------------------------------------------------------
.ruff_cache/

# ------------------------------------------------------------------------------
# Build & distribution artifacts
# ------------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
wheels/
*.whl

# ------------------------------------------------------------------------------
# Environment / secrets — NEVER commit real credentials
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# ------------------------------------------------------------------------------
# IDE & editor settings
# ------------------------------------------------------------------------------
# VS Code
.vscode/
# JetBrains / PyCharm
.idea/
*.iml
# Sublime Text
*.sublime-project
*.sublime-workspace
# Vim / Neovim
*.swp
*.swo
*~

# ------------------------------------------------------------------------------
# OS-generated files
# ------------------------------------------------------------------------------
.DS_Store           # macOS Finder metadata
Thumbs.db           # Windows thumbnail cache
desktop.ini         # Windows folder settings
ehthumbs.db

# ------------------------------------------------------------------------------
# Logs & diagnostics
# ------------------------------------------------------------------------------
*.log
logs/
*.out

# ------------------------------------------------------------------------------
# Generated pipeline reports (outputs are reproducible — no need to track them)
# ------------------------------------------------------------------------------
reports/clean_orders.csv
reports/pipeline_issues.csv
reports/pipeline_summary.json

# ------------------------------------------------------------------------------
# Jupyter notebooks (not part of this project, but kept for safety)
# ------------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
.dockerignore

# ------------------------------------------------------------------------------
# Runtime upload directories (auto-created by Flask, never commit user data)
# ------------------------------------------------------------------------------
uploads/
uploads_test/
